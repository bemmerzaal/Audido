{
  "sourceLanguage" : "en",
  "strings" : {
    "·" : {
      "comment" : "A period used to separate different pieces of information in a list.",
      "isCommentAutoGenerated" : true
    },
    "%@ / %@" : {
      "comment" : "A text displaying the current and total file size of the downloaded podcast episode.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ / %2$@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A monospaced digit view displaying the number of words in a transcription.",
      "isCommentAutoGenerated" : true
    },
    "%lld pt" : {
      "comment" : "A text view displaying the current font size setting. The content is dynamically updated as the font size changes.",
      "isCommentAutoGenerated" : true
    },
    "%lld%%" : {
      "comment" : "A text view displaying the percentage of a file that has been downloaded. The argument is the percentage of the file that has been downloaded.",
      "isCommentAutoGenerated" : true
    },
